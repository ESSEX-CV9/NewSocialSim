{
  "PostView": {
    "type": "object",
    "properties": {
      "id": {
        "type": "number"
      },
      "authorId": {
        "type": "number"
      },
      "content": {
        "type": "string"
      },
      "replyToId": {
        "type": [
          "number",
          "null"
        ],
        "description": "若为回复，指向被回复的帖子"
      },
      "quoteOfId": {
        "type": [
          "number",
          "null"
        ],
        "description": "若为引用转发，指向被引用的帖子"
      },
      "createdAt": {
        "type": "number",
        "description": "模拟时间（unix 毫秒形式）"
      },
      "likeCount": {
        "type": "number"
      },
      "repostCount": {
        "type": "number"
      },
      "quoteCount": {
        "type": "number",
        "description": "被引用次数（前端与转发数合并显示）"
      },
      "replyCount": {
        "type": "number"
      },
      "viewCount": {
        "type": "number",
        "description": "浏览量：曝光计数（卡片进入视口由客户端批量上报；模拟器层可经同一 API 或管理端注入）"
      },
      "deleted": {
        "type": "boolean",
        "description": "软删除：保留占位以维持对话串完整（\"此帖已删除\"）"
      },
      "author": {
        "$ref": "UserSummary#"
      },
      "likedByViewer": {
        "type": "boolean"
      },
      "repostedByViewer": {
        "type": "boolean"
      },
      "bookmarkedByViewer": {
        "type": "boolean",
        "description": "观察者是否已收藏（书签私密，不提供计数）"
      },
      "quoted": {
        "anyOf": [
          {
            "$ref": "PostView#"
          },
          {
            "type": "null"
          }
        ],
        "description": "被引用的帖子（只嵌一层；被删除时为墓碑视图）"
      },
      "authorFollowedByViewer": {
        "type": "boolean",
        "description": "观察者是否已关注作者（本人帖与匿名时为 false；供帖子菜单的关注快捷项）"
      },
      "media": {
        "type": "array",
        "items": {
          "$ref": "MediaView#"
        },
        "description": "附加媒体（最多 20 个，图/视频可混排），按 position 排序；墓碑帖为空数组"
      },
      "linkCard": {
        "anyOf": [
          {
            "$ref": "LinkCardView#"
          },
          {
            "type": "null"
          }
        ],
        "description": "正文首个 URL 的链接卡片；有媒体时不显示（X 行为），抓取失败为 null"
      },
      "inReplyTo": {
        "anyOf": [
          {
            "$ref": "PostView#"
          },
          {
            "type": "null"
          }
        ],
        "description": "被回复帖的一层嵌入（仅个人主页\"回复\"Tab 填充）；观察者不可见（已删/被屏蔽/被隐藏）时为 null"
      },
      "replyToHandle": {
        "type": [
          "string",
          "null"
        ],
        "description": "被回复帖作者 handle（仅\"回复\"Tab 填充）；嵌入不可见时前端降级显示\"回复"
      }
    },
    "required": [
      "author",
      "authorFollowedByViewer",
      "authorId",
      "bookmarkedByViewer",
      "content",
      "createdAt",
      "deleted",
      "id",
      "likeCount",
      "likedByViewer",
      "linkCard",
      "media",
      "quoteCount",
      "quoteOfId",
      "quoted",
      "replyCount",
      "replyToId",
      "repostCount",
      "repostedByViewer",
      "viewCount"
    ],
    "additionalProperties": false,
    "description": "面向展示的帖子：实体 + 作者 + 观察者状态 + 一层引用嵌入"
  },
  "UserSummary": {
    "type": "object",
    "properties": {
      "id": {
        "type": "number"
      },
      "handle": {
        "type": "string"
      },
      "displayName": {
        "type": "string"
      },
      "avatarUrl": {
        "type": [
          "string",
          "null"
        ],
        "description": "头像图片地址；null = 用 handle 哈希色块兜底"
      },
      "verified": {
        "$ref": "VerifiedType#",
        "description": "认证标识（蓝标/金标），随用户名各显示点展示"
      }
    },
    "required": [
      "id",
      "handle",
      "displayName",
      "avatarUrl",
      "verified"
    ],
    "additionalProperties": false,
    "description": "嵌入在帖子/通知里的轻量用户信息"
  },
  "VerifiedType": {
    "type": "string",
    "enum": [
      "none",
      "personal",
      "org"
    ],
    "description": "认证类型：none=无 / personal=个人（蓝标）/ org=组织（金标）"
  },
  "MediaView": {
    "type": "object",
    "properties": {
      "id": {
        "type": "number"
      },
      "type": {
        "type": "string",
        "enum": [
          "image",
          "video"
        ]
      },
      "url": {
        "type": "string",
        "description": "/api/media/<id>/file?w=<worldId>，公开可访问（流式引用视频为 /stream 端点）"
      },
      "width": {
        "type": [
          "number",
          "null"
        ]
      },
      "height": {
        "type": [
          "number",
          "null"
        ]
      },
      "durationMs": {
        "type": [
          "number",
          "null"
        ],
        "description": "视频时长（毫秒）；图片或未知为不出现/null"
      },
      "posterUrl": {
        "type": [
          "string",
          "null"
        ],
        "description": "视频海报图地址（外站引入时随片下载）；无海报为 null"
      },
      "storage": {
        "type": "string",
        "enum": [
          "library",
          "stream"
        ],
        "description": "视频存储形态：'library' 文件入库 / 'stream' 流式引用（源失效则不可播）"
      }
    },
    "required": [
      "id",
      "type",
      "url",
      "width",
      "height"
    ],
    "additionalProperties": false,
    "description": "媒体资源视图（文件本体经 url 流式获取）"
  },
  "LinkCardView": {
    "type": "object",
    "properties": {
      "url": {
        "type": "string"
      },
      "title": {
        "type": "string"
      },
      "description": {
        "type": [
          "string",
          "null"
        ]
      },
      "imageUrl": {
        "type": [
          "string",
          "null"
        ],
        "description": "缩略图已下载入库的本地地址"
      },
      "siteName": {
        "type": [
          "string",
          "null"
        ]
      },
      "embedUrl": {
        "type": [
          "string",
          "null"
        ],
        "description": "可嵌入播放器地址（YouTube/B 站等已知站点由 url 现算）；不支持的站点为 null"
      }
    },
    "required": [
      "url",
      "title",
      "description",
      "imageUrl",
      "siteName",
      "embedUrl"
    ],
    "additionalProperties": false,
    "description": "正文首个 URL 的 OG 链接预览卡片（抓取失败/有媒体时为 null）"
  },
  "TimelineItem": {
    "type": "object",
    "properties": {
      "type": {
        "type": "string",
        "enum": [
          "post",
          "repost"
        ]
      },
      "post": {
        "$ref": "PostView#"
      },
      "repostedBy": {
        "anyOf": [
          {
            "$ref": "UserSummary#"
          },
          {
            "type": "null"
          }
        ],
        "description": "type 为 repost 时：是谁转发进时间线的"
      },
      "activityAt": {
        "type": "number",
        "description": "排序时间：原帖为发布时间，转发为转发时间（模拟时间）"
      }
    },
    "required": [
      "type",
      "post",
      "repostedBy",
      "activityAt"
    ],
    "additionalProperties": false
  },
  "InteractionEvent": {
    "anyOf": [
      {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "const": "like"
          },
          "at": {
            "type": "number"
          },
          "post": {
            "$ref": "PostView#"
          }
        },
        "required": [
          "type",
          "at",
          "post"
        ],
        "additionalProperties": false
      },
      {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "const": "repost"
          },
          "at": {
            "type": "number"
          },
          "post": {
            "$ref": "PostView#"
          }
        },
        "required": [
          "type",
          "at",
          "post"
        ],
        "additionalProperties": false
      },
      {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "const": "follow"
          },
          "at": {
            "type": "number"
          },
          "target": {
            "$ref": "UserSummary#"
          }
        },
        "required": [
          "type",
          "at",
          "target"
        ],
        "additionalProperties": false
      }
    ],
    "description": "某账号的互动事件（赞 / 转发 / 关注），带发生时间 `at`（模拟时间，= 互动 created_at）。 供编辑器时间轴把互动落在正确时刻；真人与 NPC 的互动同源（world.db），与模拟器无关。"
  },
  "NotificationView": {
    "type": "object",
    "properties": {
      "id": {
        "type": "number"
      },
      "type": {
        "$ref": "NotificationType#"
      },
      "actor": {
        "$ref": "UserSummary#"
      },
      "actorFollowerCount": {
        "type": "number",
        "description": "actor 的粉丝数与\"是否被通知所有者关注\"——前端聚合时用于挑选最重要的头像"
      },
      "actorFollowedByViewer": {
        "type": "boolean"
      },
      "postId": {
        "type": [
          "number",
          "null"
        ]
      },
      "postExcerpt": {
        "type": [
          "string",
          "null"
        ],
        "description": "相关帖子的内容预览（前 100 字符）；无帖子或帖子已删除时为 null"
      },
      "postMedia": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "image",
                  "video"
                ]
              },
              "url": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "url"
            ],
            "additionalProperties": false
          },
          {
            "type": "null"
          }
        ],
        "description": "相关帖子的首个媒体（通知卡缩略图）；无媒体或帖子已删除时为 null"
      },
      "read": {
        "type": "boolean"
      },
      "createdAt": {
        "type": "number"
      }
    },
    "required": [
      "id",
      "type",
      "actor",
      "actorFollowerCount",
      "actorFollowedByViewer",
      "postId",
      "postExcerpt",
      "postMedia",
      "read",
      "createdAt"
    ],
    "additionalProperties": false
  },
  "NotificationType": {
    "type": "string",
    "enum": [
      "reply",
      "quote",
      "like",
      "repost",
      "follow",
      "mention"
    ]
  },
  "TrendItem": {
    "type": "object",
    "properties": {
      "tag": {
        "type": "string",
        "description": "含 # 前缀，保留首次出现的原始大小写"
      },
      "postCount": {
        "type": "number",
        "description": "近期提及该话题的帖子数（同帖同话题只计一次）"
      }
    },
    "required": [
      "tag",
      "postCount"
    ],
    "additionalProperties": false,
    "description": "趋势条目：近期被讨论的 #话题（右边栏\"有什么新鲜事\"）"
  },
  "Post": {
    "type": "object",
    "properties": {
      "id": {
        "type": "number"
      },
      "authorId": {
        "type": "number"
      },
      "content": {
        "type": "string"
      },
      "replyToId": {
        "type": [
          "number",
          "null"
        ],
        "description": "若为回复，指向被回复的帖子"
      },
      "quoteOfId": {
        "type": [
          "number",
          "null"
        ],
        "description": "若为引用转发，指向被引用的帖子"
      },
      "createdAt": {
        "type": "number",
        "description": "模拟时间（unix 毫秒形式）"
      },
      "likeCount": {
        "type": "number"
      },
      "repostCount": {
        "type": "number"
      },
      "quoteCount": {
        "type": "number",
        "description": "被引用次数（前端与转发数合并显示）"
      },
      "replyCount": {
        "type": "number"
      },
      "viewCount": {
        "type": "number",
        "description": "浏览量：曝光计数（卡片进入视口由客户端批量上报；模拟器层可经同一 API 或管理端注入）"
      },
      "deleted": {
        "type": "boolean",
        "description": "软删除：保留占位以维持对话串完整（\"此帖已删除\"）"
      }
    },
    "required": [
      "id",
      "authorId",
      "content",
      "replyToId",
      "quoteOfId",
      "createdAt",
      "likeCount",
      "repostCount",
      "quoteCount",
      "replyCount",
      "viewCount",
      "deleted"
    ],
    "additionalProperties": false,
    "description": "帖子实体（贫血模型：纯数据，无行为）"
  },
  "User": {
    "type": "object",
    "properties": {
      "id": {
        "type": "number"
      },
      "handle": {
        "type": "string"
      },
      "displayName": {
        "type": "string"
      },
      "bio": {
        "type": "string"
      },
      "createdAt": {
        "type": "number",
        "description": "模拟时间（unix 毫秒形式）"
      }
    },
    "required": [
      "id",
      "handle",
      "displayName",
      "bio",
      "createdAt"
    ],
    "additionalProperties": false,
    "description": "用户实体（贫血模型：纯数据，无行为）"
  },
  "UserProfile": {
    "type": "object",
    "properties": {
      "id": {
        "type": "number"
      },
      "handle": {
        "type": "string"
      },
      "displayName": {
        "type": "string"
      },
      "bio": {
        "type": "string"
      },
      "createdAt": {
        "type": "number",
        "description": "模拟时间（unix 毫秒形式）"
      },
      "followerCount": {
        "type": "number"
      },
      "followingCount": {
        "type": "number"
      },
      "postCount": {
        "type": "number"
      },
      "followedByViewer": {
        "type": "boolean",
        "description": "当前观察者是否已关注此人（匿名时为 false）"
      },
      "blockedByViewer": {
        "type": "boolean",
        "description": "当前观察者是否已屏蔽此人（匿名时为 false）"
      },
      "pinnedPostId": {
        "type": [
          "number",
          "null"
        ],
        "description": "本人的置顶帖 id（每用户最多一条）"
      },
      "avatarUrl": {
        "type": [
          "string",
          "null"
        ],
        "description": "头像图片地址；null = 用 handle 哈希色块兜底"
      },
      "bannerUrl": {
        "type": [
          "string",
          "null"
        ],
        "description": "主页横幅图片地址；null = 纯色占位"
      },
      "avatarMediaId": {
        "type": [
          "number",
          "null"
        ]
      },
      "bannerMediaId": {
        "type": [
          "number",
          "null"
        ]
      },
      "verified": {
        "$ref": "VerifiedType#",
        "description": "认证标识（模拟器内自助设定）"
      },
      "verifiedAt": {
        "type": [
          "number",
          "null"
        ],
        "description": "通过认证的模拟时间（unix 毫秒）；未认证或 v10 前设定的为 null"
      },
      "website": {
        "type": [
          "string",
          "null"
        ],
        "description": "简介下方展示的个人链接；null = 未设置"
      },
      "location": {
        "type": [
          "string",
          "null"
        ],
        "description": "位置（自由文本地名，可为虚构世界地点）；null = 未设置"
      },
      "birthDate": {
        "type": [
          "string",
          "null"
        ],
        "description": "出生日期（YYYY-MM-DD）；null = 未设置"
      },
      "profession": {
        "type": [
          "string",
          "null"
        ],
        "description": "专业类别 key（前端 i18n 映射展示）；null = 未设置"
      },
      "knownFollowers": {
        "type": "array",
        "items": {
          "$ref": "UserSummary#"
        },
        "description": "观察者关注的人里也关注此人的（最多 3 个，匿名或本人页为空数组）"
      },
      "knownFollowerCount": {
        "type": "number"
      }
    },
    "required": [
      "avatarMediaId",
      "avatarUrl",
      "bannerMediaId",
      "bannerUrl",
      "bio",
      "birthDate",
      "blockedByViewer",
      "createdAt",
      "displayName",
      "followedByViewer",
      "followerCount",
      "followingCount",
      "handle",
      "id",
      "knownFollowerCount",
      "knownFollowers",
      "location",
      "pinnedPostId",
      "postCount",
      "profession",
      "verified",
      "verifiedAt",
      "website"
    ],
    "additionalProperties": false,
    "description": "对外公开的用户信息（带统计数字与观察者状态）"
  },
  "AuthResponse": {
    "type": "object",
    "properties": {
      "token": {
        "type": "string"
      },
      "user": {
        "$ref": "UserProfile#"
      }
    },
    "required": [
      "token",
      "user"
    ],
    "additionalProperties": false
  },
  "WorldMeta": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "locale": {
        "type": "string",
        "enum": [
          "zh-CN",
          "en"
        ],
        "description": "该世界默认界面语言"
      },
      "clock": {
        "$ref": "ClockState#"
      },
      "calendar": {
        "$ref": "CalendarConfig#"
      },
      "contentRating": {
        "$ref": "ContentRating#",
        "description": "媒体搜索内容分级默认值（旧世界缺省按 safe）"
      },
      "createdAtRealMs": {
        "type": "number",
        "description": "创建时的真实时间（unix 毫秒），仅作管理信息，与模拟时间无关"
      }
    },
    "required": [
      "id",
      "name",
      "description",
      "locale",
      "clock",
      "calendar",
      "contentRating",
      "createdAtRealMs"
    ],
    "additionalProperties": false,
    "description": "一个世界的元数据，对应 data/worlds/<id>/world.json"
  },
  "ClockState": {
    "type": "object",
    "properties": {
      "simTimeMs": {
        "type": "number",
        "description": "保存那一刻的模拟时间（unix 毫秒形式）"
      },
      "scale": {
        "type": "number",
        "description": "流速：1 = 与现实同速，60 = 现实 1 秒过模拟 1 分钟，0 不合法（用 paused 表达暂停）"
      },
      "paused": {
        "type": "boolean"
      }
    },
    "required": [
      "simTimeMs",
      "scale",
      "paused"
    ],
    "additionalProperties": false,
    "description": "世界时钟的持久化状态（存于 world.json，加载时恢复为运行中的 SimClock）"
  },
  "CalendarConfig": {
    "type": "object",
    "properties": {
      "label": {
        "type": "string",
        "description": "历法名称，如 \"公历\" / \"天元历\""
      }
    },
    "required": [
      "label"
    ],
    "additionalProperties": false,
    "description": "仅用于展示的历法配置，如修真世界的\"天元历\""
  },
  "ContentRating": {
    "type": "string",
    "enum": [
      "safe",
      "all"
    ],
    "description": "世界级内容分级默认值：safe = 仅全年龄；all = 不过滤（R-18G 由实例配置单独把门）"
  },
  "WorldSummary": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "locale": {
        "type": "string",
        "enum": [
          "zh-CN",
          "en"
        ],
        "description": "该世界默认界面语言"
      },
      "active": {
        "type": "boolean"
      }
    },
    "required": [
      "id",
      "name",
      "description",
      "locale",
